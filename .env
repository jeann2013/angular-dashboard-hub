# ==========================================
# API Configuration - OpenTaxi API
# ==========================================
# URL base de la API OpenTaxi
# En desarrollo, usa ruta relativa para que el proxy de Vite funcione
VITE_API_URL=/api

# ==========================================
# Application Configuration
# ==========================================
# Nombre de la aplicación
VITE_APP_NAME=OpenTaxi Dashboard

# Modo de la aplicación (development, production, test)
VITE_APP_MODE=development

# ==========================================
# Authentication Configuration
# ==========================================
# Tiempo de expiración del token en milisegundos (1 hora = 3600000)
VITE_TOKEN_EXPIRY=3600000

# Habilitar/deshabilitar autenticación mock (true/false)
# Cambiar a false para usar la API real
VITE_USE_MOCK_AUTH=false

# ==========================================
# Feature Flags
# ==========================================
# Habilitar modo de depuración
VITE_DEBUG_MODE=true

# Habilitar logs detallados de API
VITE_API_LOGGING=true

# Tenant por Cliente
VITE_TOKEN_TENANT=49c621a3-6ba8-47ae-8442-e18b281f87b9
